<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background color -->
    <solid android:color="@android:color/transparent"/>

    <!-- Border -->
    <stroke android:width="2dp" android:color="#C57A50"/>

    <!-- Rounded corners -->
    <corners android:radius="8dp"/>

    <!-- Padding inside -->
    <padding
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp"/>
</shape>
